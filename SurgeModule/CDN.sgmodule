#!name= GitHub Raw Auto CDN
#!desc= 将 GitHub Raw 请求自动重定向到 CDN
#!author=Luke-Lab666
#!category=Luke-Lab666
#!homepage= https://luke-lab666.github.io/ProxyKit/
#!version= 1.0.0
#!date= 2026-05-21

[Script]
GitHub源文件自动CDN = type=http-request, pattern=^https?://raw\.githubusercontent\.com/.+, script-path=https://raw.githubusercontent.com/Luke-Lab666/ProxyKit/refs/heads/main/Scripts/cdn.js, timeout=5

[MITM]
hostname = %APPEND% raw.githubusercontent.com