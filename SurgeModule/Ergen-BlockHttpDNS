  # Generic Catch
  # ================================
  - domain_keyword:
      match: "httpdns"
      policy: REJECT

  - domain_suffix:
      match: "httpdns.pro"
      policy: REJECT

  # ================================
  # Force HTTP Engine Hosts 转换补充
  # Egern 没有 Surge force-http-engine-hosts
  # 所以这里补成 IP / Domain 拦截
  # ================================
