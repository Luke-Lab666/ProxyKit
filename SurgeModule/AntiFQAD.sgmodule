#!name=番茄小说 + 红果短剧去广告 NoMITM Safe
#!desc=无 MITM 安全版：保留番茄小说、红果短剧常见广告/日志/金币/任务拦截；放行抖音直播 Webcast / Webcast Sign / Webcast ByteGecko，避免抖音直播打不开。
#!author=Luke-Lab666
#!category=Luke-Lab666
#!tag=去广告
#!date=2026-06-21

[Rule]

# ================================
# 抖音直播救命白名单
# 必须放在所有 REJECT 前面
# ================================
DOMAIN,webcast.amemv.com,DIRECT
DOMAIN,webcast5-normal-hl.amemv.com,DIRECT
DOMAIN,webcast5-normal-lq.amemv.com,DIRECT
DOMAIN,webcast-open.douyin.com,DIRECT
DOMAIN,p3-webcast-sign.douyinpic.com,DIRECT
DOMAIN,p11-webcast-sign.douyinpic.com,DIRECT
DOMAIN,lf-webcast-gr-sourcecdn.bytegecko.com,DIRECT

# ================================
# Pangle / 穿山甲广告核心
# ================================
