#!name=YouTube Enhance Lite
#!desc=Maasea YouTube Enhance 精简版：去掉 PiP / 后台播放 / 播放器增强 / 翻译默认启用，只保留界面清理与广告辅助处理
#!category=Luke-Lab666
#!arguments=屏蔽上传按钮:true,屏蔽选段按钮:true,屏蔽Shorts按钮:false,启用调试模式:false
#!arguments-desc=屏蔽参数：[true, false]\n\n1. 已移除 player / get_watch 处理，减少播放器黑屏、加载异常概率\n2. 字幕翻译、歌词翻译默认固定为 off\n3. 本模块不再强制处理 PiP / 后台播放\n4. YouTube PiP 建议直接用官方客户端设置

# ================================
# 📌 Note
# ================================
# YouTube PiP：
# iOS 设置 -> 通用 -> 画中画
# YouTube 设置 -> 播放 -> 画中画
#
# 本版本重点：稳定、省内存、少折腾播放器响应体

[Rule]
# 🚫 阻断 QUIC / HTTP3，保证 HTTPS MITM 生效
AND,((DOMAIN-SUFFIX,googlevideo.com),(PROTOCOL,UDP)),REJECT
AND,((DOMAIN,youtubei.googleapis.com),(PROTOCOL,UDP)),REJECT
AND,((DOMAIN,youtubei-att.googleapis.com),(PROTOCOL,UDP)),REJECT

[Script]
# 🧹 Lite：不再处理 player / get_watch
youtube.response.lite = type=http-response,pattern=^https:\/\/(?:youtubei|youtubei-att)\.googleapis\.com\/youtubei\/v1\/(browse|next|search|reel\/reel_watch_sequence|guide|account\/get_setting)(\?.*)?$,requires-body=1,binary-body-mode=1,max-size=-1,engine=jsc,script-path=https://raw.githubusercontent.com/Luke-Lab666/ProxyKit/refs/heads/main/Scripts/youtube.response.js,argument="{"lyricLang":"off","captionLang":"off","blockUpload":{{{屏蔽上传按钮}}},"blockImmersive":{{{屏蔽选段按钮}}},"blockShorts":{{{屏蔽Shorts按钮}}},"debug":{{{启用调试模式}}}}"

[Map Local]
# 🚫 拦截 googlevideo 初始化广告请求
^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad data-type=text data="" status-code=200

[MITM]
hostname = %APPEND% youtubei.googleapis.com, youtubei-att.googleapis.com, *.googlevideo.com
