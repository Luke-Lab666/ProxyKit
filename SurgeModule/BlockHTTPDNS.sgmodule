[URL Rewrite]
# ================================
# IP Literal HTTPDNS API
# 这部分主要针对 App 直接请求 http://IP/path 的情况。
# HTTPS 直连 IP 如果没 MITM，URL 路径不可见，只能靠上面的 IP-CIDR。
# ================================

# DNSPod / Tencent
^https?:\/\/119\.29\.29\.29\/d - reject
^https?:\/\/182\.254\.116\.116\/d - reject

# Alibaba HTTPDNS
^https?:\/\/203\.107\.1\.1\/\d+\/ss - reject
^https?:\/\/203\.107\.1\.33\/\d+\/ss - reject
