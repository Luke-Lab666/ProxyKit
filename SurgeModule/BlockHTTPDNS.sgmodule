#!name=Block HTTPDNS
#!desc=阻止常见 HTTPDNS/私有 DoH/App 内置解析端点，强制更多请求回到 Surge DNS 框架。偏激进，建议放在模块靠前位置。
#!author=Luke-Lab666
#!category=Luke-Lab666
#!tag=DNS
#!date=2026-06-19

[General]
force-http-engine-hosts = %APPEND% 119.29.29.29:80, 182.254.116.116:80, 203.107.1.1:80, 203.107.1.33:80, 203.107.1.66:80, 203.107.1.67:80, 203.107.1.97:80, dns.weixin.qq.com:80, dns.weixin.qq.com:8080, dns.weixin.qq.com:443, aedns.weixin.qq.com:80, aedns.weixin.qq.com:443, httpdns.alicdn.com:80, httpdns.alicdn.com:443, httpdns-api.aliyuncs.com:80, httpdns-api.aliyuncs.com:443

[Rule]
# ================================
# Generic Catch
# ================================
# 大兜底：绝大多数 HTTPDNS 域名都带 httpdns
DOMAIN-KEYWORD,httpdns,REJECT

# 腾讯云 / DNSPod HTTPDNS
DOMAIN-SUFFIX,httpdns.pro,REJECT

# ================================
# Alibaba / Aliyun / Alipay
# ================================
DOMAIN,httpdns.alicdn.com,REJECT
DOMAIN,httpdns-api.aliyuncs.com,REJECT
DOMAIN,httpdns-sc.aliyuncs.com,REJECT
DOMAIN,resolvers-cn.httpdns.aliyuncs.com,REJECT
DOMAIN,httpdns.aliyuncs.com,REJECT

# 阿里 HTTPDNS 常见直连段
IP-CIDR,203.107.1.0/24,REJECT,no-resolve
IP-CIDR6,2401:b180:2000:20::10/128,REJECT,no-resolve
IP-CIDR6,2401:b180:2000:30::1c/128,REJECT,no-resolve

# ================================
# Tencent / WeChat / WeCom / QQ / Kuwo
