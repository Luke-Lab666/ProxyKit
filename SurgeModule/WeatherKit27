#!name=WeatherKit27
#!desc=iOS27 WeatherKit AQI 原位注入；降水走 forecastHourly 轻量注入。
#!category=Luke-Lab666
#!system=ios
#!arguments=AirQualityProvider:"WAQI",PrecipitationProvider:"QWeather",AQIAlgorithm:"WAQI_InstantCast_CN",ColorfulCloudsToken:"",QWeatherHost:"devapi.qweather.com",QWeatherToken:"",WAQIToken:"",ForceAllDataSets:"1",ProviderCacheTTL:"1800",ProviderLiveFetch:"1",ProviderLiveTimeout:"1800",PatchMode:"InjectAll",PrecipitationHours:"12",LogLevel:"INFO",DebugNotify:"0",StripAnalytics:"0"
#!arguments-desc=AirQualityProvider: WAQI / QWeather / ColorfulClouds / WeatherKit / Auto\nPrecipitationProvider: QWeather / ColorfulClouds / WeatherKit / Auto\nAQIAlgorithm: WAQI_InstantCast_CN / WAQI_InstantCast_US / EU_EAQI\nColorfulCloudsToken: 彩云天气 Token\nQWeatherHost: 和风天气 Host，例如 devapi.qweather.com 或专属 Host\nQWeatherToken: 和风天气 Key\nWAQIToken: WAQI Token\nForceAllDataSets: 1 补齐 iOS27 dataSets\nProviderCacheTTL: Provider 缓存秒数\nProviderLiveFetch: 1 缓存没有时短超时现场获取；0 只读缓存\nProviderLiveTimeout: 现场获取超时毫秒，建议 1200-2200\nPatchMode: Preserve / InjectAQI / InjectPrecip / InjectAll\nPrecipitationHours: 降水小时 patch 数，建议 6-12\nLogLevel: OFF / ERROR / WARN / INFO / DEBUG / ALL\nDebugNotify: 1 关键异常通知\nStripAnalytics: 1 拦截天气分析事件，调试时建议 0

[General]
force-http-engine-hosts = %APPEND% weatherkit.apple.com, weather-analytics-events.apple.com

[Rule]
DOMAIN,weatherkit.apple.com,DIRECT
DOMAIN,weather-analytics-events.apple.com,DIRECT
DOMAIN,api.caiyunapp.com,DIRECT
DOMAIN,api.waqi.info,DIRECT
DOMAIN-SUFFIX,qweather.com,DIRECT
DOMAIN-SUFFIX,qweatherapi.com,DIRECT
DOMAIN-SUFFIX,caiyunapp.com,DIRECT

[Script]
WeatherKit27 Request = type=http-request,pattern=^https?:\/\/weatherkit\.apple\.com\/api\/v2\/weather\/,requires-body=0,max-size=0,timeout=3,script-path=https://raw.githubusercontent.com/Luke-Lab666/ProxyKit/main/Scripts/WeatherKit27.request.js,argument="ForceAllDataSets={{{ForceAllDataSets}}}&LogLevel={{{LogLevel}}}"
WeatherKit27 Response = type=http-response,pattern=^https?:\/\/weatherkit\.apple\.com\/api\/v2\/weather\/,requires-body=1,binary-body-mode=1,max-size=0,timeout=7,engine=webview,script-path=https://raw.githubusercontent.com/Luke-Lab666/ProxyKit/main/Scripts/WeatherKit27.response.js,argument="AirQuality.Provider={{{AirQualityProvider}}}&Precipitation.Provider={{{PrecipitationProvider}}}&AirQuality.Calculate.Algorithm={{{AQIAlgorithm}}}&API.ColorfulClouds.Token={{{ColorfulCloudsToken}}}&API.QWeather.Host={{{QWeatherHost}}}&API.QWeather.Token={{{QWeatherToken}}}&API.WAQI.Token={{{WAQIToken}}}&Provider.CacheTTL={{{ProviderCacheTTL}}}&Provider.LiveFetch={{{ProviderLiveFetch}}}&Provider.LiveTimeout={{{ProviderLiveTimeout}}}&Provider.PatchMode={{{PatchMode}}}&Precipitation.Hours={{{PrecipitationHours}}}&LogLevel={{{LogLevel}}}&DebugNotify={{{DebugNotify}}}"
WeatherKit27 Analytics = type=http-request,pattern=^https?:\/\/weather-analytics-events\.apple\.com\/,requires-body=0,max-size=0,timeout=2,script-path=https://raw.githubusercontent.com/Luke-Lab666/ProxyKit/main/Scripts/WeatherKit27.analytics.js,argument="LogLevel={{{LogLevel}}}&StripAnalytics={{{StripAnalytics}}}"

[MITM]
hostname = %APPEND% weatherkit.apple.com, weather-analytics-events.apple.com
h2 = true
